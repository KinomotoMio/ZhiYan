# 知演 ZhiYan — 环境变量配置模板
# 复制此文件为 .env 并填入实际值: cp .env.example .env

# ── LLM API Keys ──────────────────────────────────
# 至少配置一个 provider 的 key
OPENAI_API_KEY=sk-your-openai-key-here
OPENAI_BASE_URL=https://api.openai.com/v1
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
DEEPSEEK_API_KEY=
OPENROUTER_API_KEY=

# ── PydanticAI 模型标识 ──────────────────────────
# 格式: provider:model-name (如 openai:gpt-4o, anthropic:claude-sonnet-4-5-20250929)
DEFAULT_MODEL=openai:gpt-4o-mini
STRONG_MODEL=openai:gpt-4o
VISION_MODEL=openai:gpt-4o-mini
FAST_MODEL=

# ── TTS 服务 ─────────────────────────────────────
TTS_PROVIDER=minimax
TTS_API_KEY=
TTS_BASE_URL=https://api.minimaxi.com
TTS_MODEL=speech-2.8-hd
TTS_VOICE_ID=male-qn-qingse

# ── 前端 ──────────────────────────────────────────
# Next.js 前端访问后端的地址
NEXT_PUBLIC_API_URL=http://localhost:8000
