{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Presentation",
  "description": "ZhiYan presentation payload schema",
  "type": "object",
  "required": ["presentationId", "title", "slides"],
  "properties": {
    "presentationId": {
      "type": "string",
      "description": "Unique presentation identifier"
    },
    "title": {
      "type": "string",
      "description": "Presentation title"
    },
    "theme": {
      "$ref": "#/$defs/Theme"
    },
    "slides": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/Slide"
      }
    }
  },
  "$defs": {
    "Theme": {
      "type": "object",
      "properties": {
        "primaryColor": { "type": "string" },
        "secondaryColor": { "type": "string" },
        "backgroundColor": { "type": "string" },
        "fontFamily": { "type": "string" },
        "headingFontFamily": { "type": "string" }
      }
    },
    "Slide": {
      "type": "object",
      "required": ["slideId", "layoutType"],
      "properties": {
        "slideId": {
          "type": "string",
          "description": "Unique slide identifier"
        },
        "layoutType": {
          "type": "string",
          "enum": [
            "title-slide",
            "title-content",
            "title-content-image",
            "two-column",
            "image-full",
            "section-header",
            "section-header-side",
            "blank",
            "intro-slide",
            "intro-slide-left",
            "outline-slide",
            "outline-slide-rail",
            "bullet-with-icons",
            "bullet-with-icons-cards",
            "numbered-bullets",
            "numbered-bullets-track",
            "metrics-slide",
            "metrics-slide-band",
            "metrics-with-image",
            "chart-with-bullets",
            "table-info",
            "two-column-compare",
            "image-and-description",
            "timeline",
            "quote-slide",
            "quote-banner",
            "bullet-icons-only",
            "challenge-outcome",
            "thank-you",
            "thank-you-contact"
          ],
          "description": "Layout type used by the slide"
        },
        "layoutId": {
          "type": "string",
          "description": "Template layout identifier paired with contentData"
        },
        "contentData": {
          "type": "object",
          "description": "Structured payload for the selected layout"
        },
        "background": {
          "anyOf": [
            { "$ref": "#/$defs/SceneBackground" },
            { "type": "null" }
          ],
          "description": "Optional scene-background metadata for eligible slides"
        },
        "components": {
          "type": "array",
          "description": "Legacy component payload kept for read compatibility",
          "items": {
            "$ref": "#/$defs/Component"
          }
        },
        "speakerNotes": {
          "type": "string",
          "description": "Presenter notes"
        },
        "speakerAudio": {
          "anyOf": [
            { "$ref": "#/$defs/SpeakerAudio" },
            { "type": "null" }
          ],
          "description": "Local audio metadata for presenter notes narration"
        },
        "templateSlotMapping": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          },
          "description": "Template slot name to component identifier map"
        }
      }
    },
    "SpeakerAudio": {
      "type": "object",
      "required": [
        "provider",
        "model",
        "voiceId",
        "textHash",
        "storagePath",
        "mimeType",
        "generatedAt"
      ],
      "properties": {
        "provider": { "type": "string" },
        "model": { "type": "string" },
        "voiceId": { "type": "string" },
        "textHash": { "type": "string" },
        "storagePath": { "type": "string" },
        "mimeType": { "type": "string" },
        "generatedAt": { "type": "string" }
      }
    },
    "SceneBackground": {
      "type": "object",
      "required": ["kind", "preset"],
      "properties": {
        "kind": {
          "type": "string",
          "const": "scene"
        },
        "preset": {
          "type": "string",
          "enum": [
            "hero-glow",
            "section-band",
            "outline-grid",
            "quote-focus",
            "closing-wash"
          ]
        },
        "emphasis": {
          "type": "string",
          "enum": ["subtle", "balanced", "immersive"]
        },
        "colorToken": {
          "type": "string",
          "enum": ["primary", "secondary", "neutral"]
        }
      },
      "additionalProperties": false
    },
    "Component": {
      "type": "object",
      "required": ["id", "type", "role", "position"],
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique component identifier"
        },
        "type": {
          "type": "string",
          "enum": ["text", "image", "chart", "shape"],
          "description": "Component type"
        },
        "role": {
          "type": "string",
          "enum": ["title", "subtitle", "body", "caption", "decoration", "illustration"],
          "description": "Semantic role within the slide"
        },
        "content": {
          "type": "string",
          "description": "Text content or image URL"
        },
        "position": {
          "$ref": "#/$defs/Position"
        },
        "style": {
          "$ref": "#/$defs/Style"
        },
        "chartData": {
          "type": "object",
          "description": "Chart payload for chart components"
        }
      }
    },
    "Position": {
      "type": "object",
      "required": ["x", "y", "width", "height"],
      "properties": {
        "x": { "type": "number", "description": "Left percentage (0-100)" },
        "y": { "type": "number", "description": "Top percentage (0-100)" },
        "width": { "type": "number", "description": "Width percentage (0-100)" },
        "height": { "type": "number", "description": "Height percentage (0-100)" }
      }
    },
    "Style": {
      "type": "object",
      "properties": {
        "fontSize": { "type": "number" },
        "fontWeight": { "type": "string" },
        "fontStyle": { "type": "string" },
        "color": { "type": "string" },
        "backgroundColor": { "type": "string" },
        "textAlign": { "type": "string", "enum": ["left", "center", "right"] },
        "verticalAlign": { "type": "string", "enum": ["top", "middle", "bottom"] },
        "opacity": { "type": "number", "minimum": 0, "maximum": 1 }
      }
    }
  }
}
