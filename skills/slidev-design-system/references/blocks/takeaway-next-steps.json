{
  "name": "takeaway-next-steps",
  "allowed_roles": [
    "closing",
    "recommendation"
  ],
  "required_signals": [
    "closing-line",
    "next-step-or-takeaway"
  ],
  "max_items": 3,
  "recommended_structure": "one takeaway line + 2-3 next actions",
  "anti_patterns": [
    "long-closing-bullets",
    "no-final-thesis"
  ],
  "visual_constraints": [
    "one closing line",
    "2-3 next actions max",
    "no generic thanks-only ending"
  ]
}
