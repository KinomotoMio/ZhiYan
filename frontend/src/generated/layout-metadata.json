      },
      "closing-hero": {
        "label": "结尾主屏",
        "description": "收尾与致谢用的中心主导骨架。"
      }
    },
    "tone": {
      "formal": {
        "label": "正式",
        "description": "整体气质稳健、克制，适合汇报和说明。"
      },
      "neutral": {
        "label": "中性",
        "description": "整体气质中性，偏方法说明和过程解释。"
      },
      "assertive": {
        "label": "强调",
        "description": "整体气质更强调推进感和结论导向。"
      },
      "approachable": {
        "label": "亲和",
        "description": "整体气质更易讲解，适合案例展示和说明。"
      },
      "celebratory": {
        "label": "收尾",
        "description": "整体气质更强调结束感、致谢感和庆祝感。"
      }
    },
    "style": {
      "minimal": {
        "label": "简洁",
        "description": "以简洁留白和基础层级为主的视觉风格。"
      },
      "card-based": {
        "label": "卡片化",
        "description": "通过卡片容器来组织信息的视觉风格。"
      },
      "editorial": {
        "label": "图文编排",
        "description": "强调封面感和图文编排感的视觉风格。"
      },
      "icon-led": {
        "label": "图标驱动",
        "description": "以图标作为主要视觉引导的风格。"
      },
      "data-first": {
        "label": "数据优先",
        "description": "以指标、图表或表格作为主要视觉主体的风格。"
      },
      "statement": {
        "label": "观点陈述",
        "description": "以单句观点或引用作为主要视觉焦点的风格。"
      }
    },
    "density": {
      "low": {
        "label": "低密度",
        "description": "单页元素较少，强调留白和单点焦点。"
      },
      "medium": {
        "label": "中密度",
        "description": "单页元素适中，兼顾阅读和呈现节奏。"
      },
      "high": {
        "label": "高密度",
        "description": "单页承载信息更密集，强调覆盖面与完整度。"
      }
    }
  },
