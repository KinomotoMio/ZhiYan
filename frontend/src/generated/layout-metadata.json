      }
    },
    "narrative": {
      "icon-points": {
        "label": "图标要点",
        "description": "以 3-4 个图标化要点展开正文，适合能力、优势或结论分点说明。"
      },
      "visual-explainer": {
        "label": "图文说明",
        "description": "以单张主视觉配合说明文字展开正文，适合案例、场景或产品特性介绍。"
      },
      "capability-grid": {
        "label": "能力网格",
        "description": "以多图标标签矩阵展示并列能力点，适合能力清单、模块总览或功能地图。"
      }
    },
    "evidence": {
      "default": {
        "label": "标准论据页",
        "description": "当前先保留一个默认子类，用于统一承载数据、指标或表格内容。"
      }
    },
    "comparison": {
      "default": {
        "label": "标准对比页",
        "description": "当前先保留一个默认子类，用于表达方案或结论之间的对照。"
      }
    },
    "process": {
      "default": {
        "label": "标准流程页",
        "description": "当前先保留一个默认子类，用于表达步骤与时间顺序。"
      }
    },
    "highlight": {
      "default": {
        "label": "标准强调页",
        "description": "当前先保留一个默认子类，用于突出单句观点或引用。"
      }
    },
    "closing": {
      "default": {
        "label": "标准结尾页",
        "description": "当前先保留一个默认子类，用于收尾与致谢。"
      }
    }
  },
  "variantAxes": {
    "composition": {
